---
import Layout from './Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  entry: CollectionEntry<'articles'>;
  headings?: Heading[];
}

const { entry, headings = [] } = Astro.props;
const { title, description, date, updated, category, type, tags, cover, faqs, cta, rating } = entry.data;

const categoryLabels: Record<string, string> = {
  planification: 'Planification',
  creation: 'Création & édition',
  analytics: 'Analytics',
  'seo-youtube': 'SEO YouTube',
  croissance: 'Croissance',
  automatisation: 'Automatisation',
};

const typeStyles: Record<string, string> = {
  avis: 'bg-violet-50 text-violet-600',
  comparatif: 'bg-pink-50 text-pink-600',
  guide: 'bg-sky-50 text-sky-600',
};

const readingTime = Math.ceil(entry.body.split(/\s+/).length / 200);

const displayDate = new Date(date).toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const related = allArticles
  .filter((a) => a.slug !== entry.slug && a.data.category === category)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
const readingTimeOf = (body: string) => Math.ceil(body.split(/\s+/).length / 200);

const canonicalURL = new URL(`/articles/${entry.slug}/`, Astro.site).href;
const ogImage = cover
  ? cover.startsWith('http') ? cover : new URL(cover, Astro.site).href
  : undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date,
  dateModified: updated ?? date,
  url: canonicalURL,
  author: { '@type': 'Organization', name: 'ViralKit', url: 'https://www.viralkit.fr' },
  publisher: { '@type': 'Organization', name: 'ViralKit', url: 'https://www.viralkit.fr' },
  ...(ogImage ? { image: ogImage } : {}),
};

const toolName = type === 'avis' && rating ? title.split(/\s+[Aa]vis/)[0].trim() : null;
const ratingSchema = toolName
  ? {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: toolName,
      applicationCategory: 'WebApplication',
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: rating,
        bestRating: 10,
        worstRating: 0,
        ratingCount: 1,
      },
    }
  : null;

const faqSchema = faqs && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

const jsonLd = [articleSchema, ...(ratingSchema ? [ratingSchema] : []), ...(faqSchema ? [faqSchema] : [])];

const hasToc = headings.filter((h) => h.depth === 2 || h.depth === 3).length > 2;
---

<Layout
  title={`${title} | ViralKit`}
  description={description}
  canonical={canonicalURL}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <!-- Barre de progression lecture -->
  <div
    id="reading-progress"
    class="fixed top-0 left-0 h-[3px] bg-violet-500 z-[60] w-0 transition-[width] duration-100 ease-out"
    role="progressbar"
    aria-hidden="true"
  ></div>

  <main class={`mx-auto max-w-5xl px-4 py-10 ${cta ? 'pb-28' : ''}`}>

    <!-- Disclosure affiliés -->
    <div class="mb-8 flex items-start gap-2.5 rounded-xl bg-amber-50 border border-amber-200 px-4 py-3 text-xs text-amber-800 leading-relaxed">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>
        Cet article contient des <strong>liens affiliés</strong>. Si vous achetez via ces liens, nous touchons une commission sans surcoût pour vous. Nos avis restent toujours indépendants.
      </span>
    </div>

    <!-- Grid: contenu + TOC sidebar -->
    <div class={hasToc ? 'lg:grid lg:grid-cols-[1fr_220px] lg:gap-14 lg:items-start' : ''}>

      <!-- Colonne principale -->
      <div>
        <!-- En-tête article -->
        <div class="mb-8">
          <div class="flex items-center gap-2 flex-wrap">
            <span class={`inline-block text-xs font-semibold uppercase tracking-wide px-2 py-0.5 rounded-md ${typeStyles[type] ?? 'bg-slate-100 text-slate-600'}`}>
              {type}
            </span>
            <a
              href={`/categorie/${category}/`}
              class="inline-block text-xs text-slate-500 bg-slate-100 hover:bg-slate-200 px-2 py-0.5 rounded-md transition-colors"
            >
              {categoryLabels[category] ?? category}
            </a>
          </div>
          <h1 class="mt-3 text-3xl md:text-4xl font-bold text-slate-900 leading-tight tracking-tight">
            {title}
          </h1>
          <p class="mt-3 text-lg text-slate-600 leading-relaxed">{description}</p>
          <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-2">
            <p class="text-sm text-slate-400">
              <time datetime={date}>{displayDate}</time> · {readingTime} min de lecture
              {updated && updated !== date && (
                <span>
                  {' '}· Mis à jour :{' '}
                  <time datetime={updated}>
                    {new Date(updated).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
                  </time>
                </span>
              )}
            </p>
            {type === 'avis' && rating && (
              <div class="flex items-center gap-1.5">
                <div class="flex gap-0.5">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-4 h-4 ${i < Math.round(rating / 2) ? 'text-amber-400 fill-amber-400' : 'text-slate-200 fill-slate-200'}`} viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <span class="text-sm font-semibold text-slate-700">{rating}/10</span>
              </div>
            )}
          </div>
        </div>

        <!-- Cover -->
        {cover && (
          <div class="mb-8 rounded-2xl overflow-hidden">
            <img
              src={cover}
              alt={title}
              class="w-full h-auto object-cover"
              loading="eager"
              width="768"
              height="432"
            />
          </div>
        )}

        <!-- TOC mobile -->
        {hasToc && (
          <details class="lg:hidden mb-8 rounded-xl border border-slate-200 bg-slate-50 p-4">
            <summary class="text-sm font-semibold text-slate-700 cursor-pointer select-none">
              Dans cet article
            </summary>
            <div class="mt-3">
              <TableOfContents headings={headings} />
            </div>
          </details>
        )}

        <!-- Contenu MDX -->
        <article
          id="article-content"
          class="prose prose-slate prose-base max-w-none
            prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-slate-900
            prose-a:text-violet-600 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-slate-900
            prose-table:text-sm
            prose-th:bg-slate-100 prose-th:font-semibold
            prose-td:border prose-td:border-slate-200 prose-td:px-3 prose-td:py-2
            prose-th:border prose-th:border-slate-200 prose-th:px-3 prose-th:py-2
            prose-img:rounded-xl"
        >
          <slot />
        </article>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-10 pt-6 border-t border-slate-100 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <!-- TOC sidebar desktop -->
      {hasToc && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <TableOfContents headings={headings} />
          </div>
        </aside>
      )}
    </div>

    <!-- Articles liés -->
    {related.length > 0 && (
      <section class="mt-16 pt-10 border-t border-slate-100">
        <h2 class="text-xl font-bold text-slate-900 mb-6">Articles similaires</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              slug={a.slug}
              category={a.data.category}
              type={a.data.type}
              date={a.data.date}
              readingTime={readingTimeOf(a.body)}
              rating={a.data.rating}
            />
          ))}
        </div>
      </section>
    )}
  </main>

  <!-- Sticky CTA bas de page -->
  {cta && (
    <div
      id="sticky-cta"
      class="fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-t border-slate-200 shadow-[0_-4px_24px_rgba(0,0,0,0.08)]"
    >
      <div class="mx-auto max-w-5xl px-4 py-3 flex items-center justify-between gap-4">
        <p class="text-sm text-slate-600 hidden sm:block truncate">{cta.note ?? description}</p>
        <div class="flex items-center gap-3 ml-auto">
          <a
            href={cta.url}
            target="_blank"
            rel="nofollow noopener sponsored"
            class="shrink-0 bg-violet-600 text-white px-6 py-2.5 rounded-xl text-sm font-semibold hover:bg-violet-700 transition-colors"
          >
            {cta.label}
          </a>
          <button
            id="close-cta"
            aria-label="Fermer"
            class="text-slate-400 hover:text-slate-600 transition-colors p-1"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  )}
</Layout>

<script>
  const bar = document.getElementById('reading-progress');
  const article = document.getElementById('article-content');

  if (bar && article) {
    const update = () => {
      const top = article.getBoundingClientRect().top + window.scrollY;
      const height = article.offsetHeight;
      const progress = Math.max(0, Math.min(100, ((window.scrollY - top + window.innerHeight * 0.3) / height) * 100));
      bar.style.width = `${progress}%`;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  document.getElementById('close-cta')?.addEventListener('click', () => {
    document.getElementById('sticky-cta')?.remove();
  });
</script>
