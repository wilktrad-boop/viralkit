---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const readingTime = (body: string) => Math.ceil(body.split(/\s+/).length / 200);

const featured = allArticles.find((a) => a.data.featured) ?? allArticles.find((a) => a.data.cta);

const stats = [
  { value: '15+', label: 'outils comparés' },
  { value: `${allArticles.length}`, label: 'articles' },
  { value: '100%', label: 'indépendant' },
  { value: '2026', label: 'mis à jour' },
];

const whyItems = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Tests réels',
    desc: 'Chaque outil est testé pendant plusieurs semaines avant la publication de notre avis.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Prix à jour',
    desc: 'Nous vérifions régulièrement les tarifs. Aucun avis avec des prix obsolètes.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>`,
    title: 'Affiliés déclarés',
    desc: 'Les liens affiliés sont clairement signalés. Nos avis restent toujours neutres.',
  },
];
---

<Layout
  title="ViralKit — Les meilleurs outils pour Instagram, TikTok & YouTube"
  description="Comparatifs indépendants et avis complets sur les meilleurs outils pour grandir sur Instagram, TikTok et YouTube. Tests réels, prix à jour, affiliés déclarés."
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-16 md:py-20 px-4" style="background: #1a0a2e;">
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(124,58,237,0.3) 0%, transparent 70%); filter: blur(60px);"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(196,131,255,0.15) 0%, transparent 70%); filter: blur(60px);"></div>

    <div class="relative mx-auto max-w-5xl">
      <div class="grid md:grid-cols-[1fr_300px] gap-10 items-center">

        <div>
          <span class="inline-block mb-4 px-3 py-1.5 rounded-full text-violet-300 text-sm font-medium" style="background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3);">
            ✦ Comparatifs indépendants 2026
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-white mb-5 leading-tight tracking-tight">
            Les meilleurs outils pour <span class="text-violet-400">Instagram, TikTok</span> & YouTube
          </h1>
          <p class="text-xl mb-8 leading-relaxed" style="color: rgba(216,180,254,0.8);">
            Avis honnêtes, comparatifs détaillés et prix réels — pour choisir les outils qui font vraiment grandir votre audience.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="#articles"
              class="inline-block bg-violet-600 text-white px-7 py-3 rounded-xl font-semibold hover:bg-violet-500 transition-colors shadow-lg shadow-violet-900/40"
            >
              Voir les comparatifs
            </a>
            <a
              href="#pourquoi"
              class="inline-block px-7 py-3 rounded-xl font-semibold transition-colors"
              style="background: rgba(255,255,255,0.07); color: #ddd6fe; border: 1px solid rgba(255,255,255,0.12);"
            >
              Notre approche
            </a>
          </div>
        </div>

        <!-- Card outil vedette -->
        {featured && (
          <div class="bg-white rounded-2xl border border-slate-200 shadow-xl shadow-violet-900/20 p-6 flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-violet-600 bg-violet-50 px-2 py-0.5 rounded-md uppercase tracking-wide">
                Notre favori
              </span>
              <div class="flex gap-0.5 text-amber-400 text-base">
                ★★★★★
              </div>
            </div>
            <div>
              <h2 class="text-lg font-bold text-slate-900">{featured.data.title.split(':')[0]}</h2>
              <p class="mt-1 text-sm text-slate-500 leading-relaxed line-clamp-3">{featured.data.description}</p>
            </div>
            <div class="flex flex-col gap-2 pt-2 border-t border-slate-100">
              <a
                href={featured.data.cta?.url}
                target="_blank"
                rel="nofollow noopener sponsored"
                class="w-full text-center bg-violet-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:bg-violet-500 transition-colors"
              >
                {featured.data.cta?.label ?? 'Essayer gratuitement'}
              </a>
              <a
                href={`/${featured.slug}/`}
                class="w-full text-center text-sm text-slate-600 hover:text-violet-600 transition-colors py-1"
              >
                Lire l'avis complet →
              </a>
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-slate-100 bg-slate-50">
    <div class="mx-auto max-w-5xl px-4 py-5 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {stats.map((s) => (
        <div>
          <div class="text-2xl font-bold text-violet-600">{s.value}</div>
          <div class="text-sm text-slate-500">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-4 py-16 space-y-20">

    <!-- Articles -->
    {allArticles.length > 0 && (
      <section id="articles">
        <h2 class="text-2xl font-bold text-slate-900 mb-8 tracking-tight">Derniers avis et comparatifs</h2>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {allArticles.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              category={article.data.category}
              type={article.data.type}
              date={article.data.date}
              readingTime={readingTime(article.body)}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Pourquoi nous faire confiance -->
    <section id="pourquoi" class="bg-slate-50 rounded-3xl p-8 md:p-12">
      <h2 class="text-2xl font-bold text-slate-900 mb-10 text-center tracking-tight">Pourquoi nous faire confiance ?</h2>
      <div class="grid gap-8 md:grid-cols-3">
        {whyItems.map((item) => (
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-violet-100 text-violet-600 mb-4">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-semibold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
