---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Callout from '../../components/mdx/Callout.astro';
import BuyButton from '../../components/mdx/BuyButton.astro';
import ProsCons from '../../components/mdx/ProsCons.astro';
import SpecTable from '../../components/mdx/SpecTable.astro';
import FAQ from '../../components/mdx/FAQ.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
---

<ArticleLayout entry={entry} headings={headings}>
  <Content components={{ Callout, BuyButton, ProsCons, SpecTable, FAQ }} />
</ArticleLayout>
