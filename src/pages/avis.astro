---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles', ({ data }) => !data.draft && data.type === 'avis');
allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const readingTime = (body: string) => Math.ceil(body.split(/\s+/).length / 200);
---

<Layout
  title="Avis outils social media — ViralKit"
  description="Nos avis complets et honnêtes sur les meilleurs outils pour Instagram, TikTok et YouTube. Tests réels, prix à jour."
>
  <main class="mx-auto max-w-5xl px-4 py-12">
    <div class="mb-10">
      <span class="inline-block text-xs font-semibold text-violet-600 bg-violet-50 px-2 py-0.5 rounded-md uppercase tracking-wide mb-3">Avis</span>
      <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Avis outils social media</h1>
      <p class="mt-3 text-lg text-slate-600">Nos tests approfondis sur les outils de croissance, planification et analytics pour les réseaux sociaux.</p>
    </div>
    {allArticles.length > 0 ? (
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {allArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            category={article.data.category}
            type={article.data.type}
            date={article.data.date}
            readingTime={readingTime(article.body)}
          />
        ))}
      </div>
    ) : (
      <p class="text-slate-500">Aucun avis publié pour l'instant.</p>
    )}
  </main>
</Layout>
