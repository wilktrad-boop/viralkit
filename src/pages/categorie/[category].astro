---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const categories = ['planification', 'creation', 'analytics', 'seo-youtube', 'croissance', 'automatisation'];
  return categories.map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params;

const categoryMeta: Record<string, { label: string; description: string; color: string }> = {
  planification: {
    label: 'Planification & scheduling',
    description: 'Comparatifs et avis des meilleurs outils pour programmer et planifier vos publications sur Instagram, TikTok et YouTube.',
    color: 'text-blue-600 bg-blue-50',
  },
  creation: {
    label: 'Création & édition',
    description: 'Les meilleurs outils de création visuelle et de montage vidéo pour vos contenus sur les réseaux sociaux.',
    color: 'text-orange-600 bg-orange-50',
  },
  analytics: {
    label: 'Analytics & statistiques',
    description: 'Outils d\'analyse de performance pour suivre votre croissance et comprendre votre audience sur les réseaux sociaux.',
    color: 'text-teal-600 bg-teal-50',
  },
  'seo-youtube': {
    label: 'SEO YouTube',
    description: 'Extensions et outils pour optimiser vos vidéos YouTube, trouver les bons mots-clés et analyser la concurrence.',
    color: 'text-red-600 bg-red-50',
  },
  croissance: {
    label: 'Croissance & formation',
    description: 'Formations, coaching et outils de croissance pour développer votre audience sur les réseaux sociaux.',
    color: 'text-violet-600 bg-violet-50',
  },
  automatisation: {
    label: 'Automatisation',
    description: 'Outils d\'automatisation des interactions, chatbots et DM automation pour gérer votre communauté à grande échelle.',
    color: 'text-slate-600 bg-slate-100',
  },
};

const meta = categoryMeta[category!] ?? { label: category, description: '', color: 'text-slate-600 bg-slate-100' };

const allArticles = await getCollection('articles', ({ data }) => !data.draft && data.category === category);
allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const readingTime = (body: string) => Math.ceil(body.split(/\s+/).length / 200);

const avis = allArticles.filter((a) => a.data.type === 'avis');
const comparatifs = allArticles.filter((a) => a.data.type === 'comparatif');
const guides = allArticles.filter((a) => a.data.type === 'guide');
---

<Layout
  title={`${meta.label} — ViralKit`}
  description={meta.description}
>
  <main class="mx-auto max-w-5xl px-4 py-12">
    <div class="mb-10">
      <span class={`inline-block text-xs font-semibold px-2 py-0.5 rounded-md uppercase tracking-wide mb-3 ${meta.color}`}>
        {meta.label}
      </span>
      <h1 class="text-3xl font-bold text-slate-900 tracking-tight">{meta.label}</h1>
      <p class="mt-3 text-lg text-slate-600">{meta.description}</p>
    </div>

    {allArticles.length === 0 && (
      <p class="text-slate-500">Aucun article publié dans cette catégorie pour l'instant.</p>
    )}

    {avis.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-3">
          <span class="text-sm font-semibold bg-violet-50 text-violet-700 px-2.5 py-1 rounded-lg uppercase tracking-wide">Avis</span>
        </h2>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {avis.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              category={article.data.category}
              type={article.data.type}
              date={article.data.date}
              readingTime={readingTime(article.body)}
            />
          ))}
        </div>
      </section>
    )}

    {comparatifs.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-3">
          <span class="text-sm font-semibold bg-pink-50 text-pink-700 px-2.5 py-1 rounded-lg uppercase tracking-wide">Comparatifs</span>
        </h2>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {comparatifs.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              category={article.data.category}
              type={article.data.type}
              date={article.data.date}
              readingTime={readingTime(article.body)}
            />
          ))}
        </div>
      </section>
    )}

    {guides.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-3">
          <span class="text-sm font-semibold bg-sky-50 text-sky-700 px-2.5 py-1 rounded-lg uppercase tracking-wide">Guides</span>
        </h2>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {guides.map((article) => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              category={article.data.category}
              type={article.data.type}
              date={article.data.date}
              readingTime={readingTime(article.body)}
            />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
