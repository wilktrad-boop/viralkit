---
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const avis = allArticles.filter((a) => a.data.type === 'avis').slice(0, 4);
const comparatifs = allArticles.filter((a) => a.data.type === 'comparatif').slice(0, 4);

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-100 mt-20 bg-slate-50">
  <div class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr]">

      <!-- Marque -->
      <div>
        <a href="/" class="text-lg font-bold tracking-tight">
          <span class="text-violet-600">viral</span><span class="text-slate-900">kit</span><span class="text-slate-400 font-normal">.fr</span>
        </a>
        <p class="mt-3 text-sm text-slate-500 leading-relaxed max-w-xs">
          Comparatifs indépendants des meilleurs outils pour Instagram, TikTok, YouTube et les réseaux sociaux.
        </p>
        <p class="mt-4 text-xs text-slate-400">
          Contenu indépendant · Liens affiliés déclarés
        </p>
      </div>

      <!-- Avis -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Avis</p>
        <ul class="space-y-2">
          {avis.map((a) => (
            <li>
              <a
                href={`/articles/${a.slug}/`}
                class="text-sm text-slate-600 hover:text-violet-600 transition-colors line-clamp-1"
              >
                {a.data.title}
              </a>
            </li>
          ))}
          <li>
            <a href="/avis" class="text-sm text-violet-600 font-medium hover:underline">
              Tous les avis →
            </a>
          </li>
        </ul>
      </div>

      <!-- Comparatifs + Legal -->
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">Comparatifs</p>
        <ul class="space-y-2">
          {comparatifs.map((a) => (
            <li>
              <a
                href={`/articles/${a.slug}/`}
                class="text-sm text-slate-600 hover:text-violet-600 transition-colors line-clamp-1"
              >
                {a.data.title}
              </a>
            </li>
          ))}
          <li>
            <a href="/comparatifs" class="text-sm text-violet-600 font-medium hover:underline">
              Tous les comparatifs →
            </a>
          </li>
        </ul>

        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mt-8 mb-4">Légal</p>
        <ul class="space-y-2">
          <li><a href="/mentions-legales/" class="text-sm text-slate-600 hover:text-violet-600 transition-colors">Mentions légales</a></li>
          <li><a href="/confidentialite/" class="text-sm text-slate-600 hover:text-violet-600 transition-colors">Confidentialité</a></li>
          <li><a href="/a-propos/" class="text-sm text-slate-600 hover:text-violet-600 transition-colors">À propos</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-slate-200 text-center text-xs text-slate-400">
      © {year} viralkit.fr
    </div>
  </div>
</footer>
