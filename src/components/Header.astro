---
const categories = [
  { label: 'Planification', href: '/categorie/planification' },
  { label: 'Création & édition', href: '/categorie/creation' },
  { label: 'Analytics', href: '/categorie/analytics' },
  { label: 'SEO YouTube', href: '/categorie/seo-youtube' },
  { label: 'Croissance', href: '/categorie/croissance' },
  { label: 'Automatisation', href: '/categorie/automatisation' },
];

const topNav = [
  { label: 'Avis', href: '/avis' },
  { label: 'Comparatifs', href: '/comparatifs' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const isCategoryActive = categories.some((c) => pathname.startsWith(c.href));
---

<header
  id="site-header"
  class="border-b border-slate-100 bg-white/90 backdrop-blur-md sticky top-0 z-50 transition-shadow duration-200"
>
  <div class="mx-auto max-w-5xl px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight shrink-0">
      <span class="text-violet-600">viral</span><span class="text-slate-900">kit</span><span class="text-slate-400 font-normal">.fr</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-1">

      <!-- Dropdown Catégories -->
      <div class="relative group">
        <button
          class={`flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-lg transition-colors ${
            isCategoryActive
              ? 'text-violet-600 bg-violet-50'
              : 'text-slate-600 hover:text-violet-600 hover:bg-slate-50'
          }`}
        >
          Catégories
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
          <div class="bg-white rounded-xl border border-slate-200 shadow-lg shadow-slate-200/60 py-2 min-w-[200px]">
            {categories.map((cat) => (
              <a
                href={cat.href}
                class={`block px-4 py-2 text-sm transition-colors ${
                  isActive(cat.href)
                    ? 'text-violet-600 bg-violet-50 font-medium'
                    : 'text-slate-600 hover:text-violet-600 hover:bg-slate-50'
                }`}
              >
                {cat.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Avis / Comparatifs -->
      {topNav.map((item) => (
        <a
          href={item.href}
          class={`px-3 py-1.5 text-sm font-medium rounded-lg transition-colors ${
            isActive(item.href)
              ? 'text-violet-600 bg-violet-50'
              : 'text-slate-600 hover:text-violet-600 hover:bg-slate-50'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="sm:hidden p-2 rounded-lg text-slate-600 hover:bg-slate-100 transition-colors"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-slate-100 bg-white/95 backdrop-blur-md px-4 pb-4">
    <nav class="flex flex-col gap-1 pt-2">
      <p class="px-3 pt-2 pb-1 text-xs font-semibold text-slate-400 uppercase tracking-widest">Catégories</p>
      {categories.map((cat) => (
        <a
          href={cat.href}
          class={`px-3 py-2 rounded-xl text-sm font-medium transition-colors ${
            isActive(cat.href)
              ? 'bg-violet-50 text-violet-600'
              : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
          }`}
        >
          {cat.label}
        </a>
      ))}
      <div class="border-t border-slate-100 mt-2 pt-2">
        {topNav.map((item) => (
          <a
            href={item.href}
            class={`block px-3 py-2 rounded-xl text-sm font-medium transition-colors ${
              isActive(item.href)
                ? 'bg-violet-50 text-violet-600'
                : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('shadow-md', window.scrollY > 8);
  }, { passive: true });
</script>
