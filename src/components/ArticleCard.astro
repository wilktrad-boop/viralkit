---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  type: string;
  date: string;
  readingTime: number;
  rating?: number;
}

const { title, description, slug, category, type, date, readingTime, rating } = Astro.props;
const filledStars = rating ? Math.round(rating / 2) : 0;

const isNew = (Date.now() - new Date(date).getTime()) < 30 * 24 * 60 * 60 * 1000;

const typeStyles: Record<string, { badge: string; border: string; hover: string }> = {
  avis: {
    badge: 'bg-violet-50 text-violet-700',
    border: 'hover:border-violet-200',
    hover: 'group-hover:text-violet-700',
  },
  comparatif: {
    badge: 'bg-pink-50 text-pink-700',
    border: 'hover:border-pink-200',
    hover: 'group-hover:text-pink-700',
  },
  guide: {
    badge: 'bg-sky-50 text-sky-700',
    border: 'hover:border-sky-200',
    hover: 'group-hover:text-sky-700',
  },
};

const categoryLabels: Record<string, string> = {
  planification: 'Planification',
  creation: 'Création & édition',
  analytics: 'Analytics',
  'seo-youtube': 'SEO YouTube',
  croissance: 'Croissance',
  automatisation: 'Automatisation',
};

const style = typeStyles[type] ?? {
  badge: 'bg-slate-100 text-slate-700',
  border: 'hover:border-slate-300',
  hover: 'group-hover:text-violet-600',
};
---

<a
  href={`/articles/${slug}/`}
  class={`group rounded-2xl border border-slate-200 bg-white p-6 hover:shadow-lg ${style.border} transition-all block`}
>
  <div class="flex items-center gap-2 flex-wrap">
    <span class={`inline-block text-xs font-semibold uppercase tracking-wide px-2 py-0.5 rounded-md ${style.badge}`}>
      {type}
    </span>
    <span class="inline-block text-xs text-slate-400 px-2 py-0.5 rounded-md bg-slate-50">
      {categoryLabels[category] ?? category}
    </span>
    {isNew && (
      <span class="inline-block text-xs font-semibold bg-violet-600 text-white px-2 py-0.5 rounded-md">
        Nouveau
      </span>
    )}
  </div>
  <h3 class={`mt-3 text-base font-semibold text-slate-900 ${style.hover} transition-colors line-clamp-2`}>
    {title}
  </h3>
  <p class="mt-2 text-sm text-slate-500 line-clamp-3 leading-relaxed">{description}</p>
  {type === 'avis' && rating && (
    <div class="mt-3 flex items-center gap-1.5">
      <div class="flex gap-0.5">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class={`w-3.5 h-3.5 ${i < filledStars ? 'text-amber-400 fill-amber-400' : 'text-slate-200 fill-slate-200'}`} viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <span class="text-xs text-slate-500 font-medium">{rating}/10</span>
    </div>
  )}
  <div class="mt-3 flex items-center justify-between">
    <span class="text-xs text-slate-400">{readingTime} min de lecture</span>
    <span class="text-xs font-medium text-violet-600 opacity-0 group-hover:opacity-100 transition-opacity">
      Lire →
    </span>
  </div>
</a>
