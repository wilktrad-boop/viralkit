---
interface Props {
  pros?: string[];
  cons?: string[];
}
const { pros = [], cons = [] } = Astro.props;
---
<div class="not-prose my-6 grid gap-4 md:grid-cols-2">
  <div class="rounded-xl bg-green-50 border border-green-100 p-4">
    <h4 class="mb-3 font-semibold text-green-800 text-sm">✓ Points forts</h4>
    <ul class="space-y-1.5">
      {pros.map((p) => <li class="text-sm text-green-700 flex gap-2"><span class="shrink-0 mt-0.5">•</span><span>{p}</span></li>)}
    </ul>
  </div>
  <div class="rounded-xl bg-red-50 border border-red-100 p-4">
    <h4 class="mb-3 font-semibold text-red-800 text-sm">✗ Points faibles</h4>
    <ul class="space-y-1.5">
      {cons.map((c) => <li class="text-sm text-red-700 flex gap-2"><span class="shrink-0 mt-0.5">•</span><span>{c}</span></li>)}
    </ul>
  </div>
</div>
